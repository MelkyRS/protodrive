# Proto Drive: Backend Configuration

# Server
PORT=3000
DEBUG=true
NODE_ENV=development

# Security (Client must send this in 'Authorization' header)
API_SECRET=your_super_secret_api_key

# Supabase Configuration
SUPABASE_URL=https://your-project-id.supabase.co
# service_role key is required for administrative tasks, but app also checks for anon key if service role is missing
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_ANON_KEY=your_anon_key

# Discord Configuration
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_CHANNEL_ID=your_storage_channel_id
DISCORD_BACKUP_CHANNEL_ID=your_backup_channel_id_optional